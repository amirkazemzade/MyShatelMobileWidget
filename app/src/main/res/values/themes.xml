<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyShatelMobileWidget" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.MyShatelMobileWidget.AppWidgetContainerParent" parent="Theme.AppCompat">
        <!-- Radius of the outer bound of widgets to make the rounded corners -->
        <item name="appWidgetRadius">16dp</item>
        <!--
        Radius of the inner view's bound of widgets to make the rounded corners.
        It needs to be 8dp or less than the value of appWidgetRadius
        -->
        <item name="appWidgetInnerRadius">8dp</item>
    </style>

    <style name="Theme.MyShatelMobileWidget.AppWidgetContainer" parent="Theme.MyShatelMobileWidget.AppWidgetContainerParent">
        <!-- Apply padding to avoid the content of the widget colliding with the rounded corners -->
        <item name="appWidgetPadding">16dp</item>
    </style>

    <style name="Theme.WidgetConfig" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>